[project]
title = Asobi Arena Demo
version = 1.0.0
dependencies#0 = https://github.com/defold/extension-websocket/archive/master.zip

[display]
width = 1280
height = 720

[bootstrap]
main_collection = /main/main.collectionc

[input]
game_binding = /input/game.input_bindingc

[script]
shared_state = 1

[network]
http_timeout = 10
